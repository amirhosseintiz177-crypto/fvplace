{
  "name": "fvplace-cloud-storage",
  "version": "0.2.0",
  "private": true,
  "description": "A futuristic 2026 SaaS-style cloud storage platform with Next.js, Express, MongoDB, JWT/OAuth, Socket.io, and S3-compatible storage.",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "nodemon apps/api/src/server.js",
    "dev:web": "next dev apps/web",
    "start": "node apps/api/src/server.js",
    "start:web": "next start apps/web",
    "build:web": "next build apps/web",
    "check": "node scripts/check-syntax.js"
  },
  "keywords": [
    "cloud-storage",
    "nextjs",
    "mongodb",
    "express",
    "socket.io",
    "s3",
    "saas"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.726.1",
    "@aws-sdk/s3-request-presigner": "^3.726.1",
    "@next/third-parties": "^15.1.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "next": "^15.1.4",
    "nanoid": "^3.3.8",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
