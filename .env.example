# Shared
NODE_ENV=development
APP_NAME=FVPlace Nova
PUBLIC_APP_URL=http://localhost:3000

# API
API_PORT=4000
API_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
MONGODB_URI=mongodb://127.0.0.1:27017/fvplace_nova
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=600
MAX_UPLOAD_MB=250
LOCAL_STORAGE_DIR=uploads

# OAuth providers (configure in production)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# S3-compatible object storage. Leave empty for local development storage.
S3_ENDPOINT=https://s3.example.com
S3_REGION=auto
S3_BUCKET=fvplace
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
